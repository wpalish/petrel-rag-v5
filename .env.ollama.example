# =============================================================================
# Профиль ЗАПУСКА НА НОУТБУКЕ через Ollama (без vLLM/GPU/Docker).
# Скопируй в .env:  cp .env.ollama.example .env
#
# Требуется: запущенный Ollama (`ollama serve`) и модель
# (`ollama pull qwen2.5:7b-instruct`). Эмбеддинги/reranker — локально на CPU.
# Qdrant — в embedded-режиме (локальный файл), сервер не нужен.
# =============================================================================

# LLM → локальный Ollama отдаёт OpenAI-совместимый /v1, поэтому тот же
# AsyncOpenAI-клиент работает без изменений кода:
VLLM_HOST=localhost
VLLM_PORT=11434
LLM_MODEL=qwen2.5:7b-instruct

# Эмбеддинги локально (sentence-transformers), без TEI:
USE_TEI=false
EMBED_MODEL=BAAI/bge-m3
EMBED_DIM=1024
EMBED_DEVICE=cpu

# Reranker локально на CPU:
USE_RERANKER=true
RERANKER_DEVICE=cpu

# Qdrant в embedded-режиме: локальный файл вместо сервера/Docker
QDRANT_PATH=data/qdrant_local
QDRANT_COLLECTION=corporate_knowledge

# Hybrid: BM25 (TEI-sparse выключен — нет TEI-сервиса)
USE_HYBRID=true
SPARSE_METHOD=bm25
TEI_SPARSE_ENABLED=false

# Пути локальные (не /app, как в контейнере)
TESTSET_PATH=tests/testset.json
EVAL_RESULTS_PATH=evaluation/results.json
DOCS_DIR=data/docs
INDEX_DIR=data/index
MODELS_DIR=models

AUTH_ENABLED=false
METRICS_ENABLED=true
