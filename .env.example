# =============================================================================
# Пример конфигурации окружения для On-Premise RAG v5.
# Скопируйте в .env и при необходимости отредактируйте:
#   cp .env.example .env
# =============================================================================

# --- Сервисы ---
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=corporate_knowledge

VLLM_HOST=vllm
VLLM_PORT=8000

TEI_HOST=tei-embeddings
TEI_PORT=80

# --- Модели ---
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct-AWQ
EMBED_MODEL=BAAI/bge-m3
EMBED_DIM=1024
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# --- LLM (v4: streaming для TTFT) ---
LLM_STREAM=True
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024
LLM_TIMEOUT=120.0

# --- Reranker ---
USE_RERANKER=True
RERANKER_NORMALIZE=True
RERANKER_DEVICE=cpu

# --- Embeddings: TEI vs local ---
USE_TEI=False
EMBED_DEVICE=cpu

# --- RAG-параметры (КАЛИБРУЕМЫЕ) ---
CHUNK_SIZE=512
CHUNK_OVERLAP=80
PARENT_CHUNK_SIZE=1400
PARENT_CHUNK_OVERLAP=150
TOP_K=8
RERANK_TOP_K=5
MIN_RERANK_SCORE=0.30       # после калибровки: ./scripts/calibrate_threshold.py

# --- PDR ---
USE_PDR=True

# --- Hybrid Search (v3) ---
USE_HYBRID=True
SPARSE_METHOD=bm25           # 'bm25' или 'bge_m3_sparse' (v5: требует TEI)
RRF_K=60
DENSE_TOP_K=16
SPARSE_TOP_K=16

# --- v5: Sparse через TEI (bge-m3 sparse, точнее BM25) ---
TEI_SPARSE_ENABLED=False    # True для активации bge-m3 sparse через TEI

# --- Дедупликация по chunk_hash ---
USE_CHUNK_HASH_DEDUP=True

# --- Evaluation (v4: локальный LLM-judge, БЕЗ RAGAS) ---
TESTSET_PATH=/app/tests/testset.json
EVAL_RESULTS_PATH=/app/evaluation/results.json
TARGET_FAITHFULNESS=0.85
TARGET_ANSWER_RELEVANCY=0.80
TARGET_LANGUAGE_PURITY=0.95

# --- v5: A/B Prompt Testing ---
PROMPT_VARIANT=strict       # strict | balanced | concise

# --- v5: Auth (Basic Auth) ---
AUTH_ENABLED=False          # True для защиты /chat, /ingest, /documents, /evaluation
AUTH_USER=admin
AUTH_PASSWORD=changeme      # ОБЯЗАТЕЛЬНО сменить в production!
AUTH_PUBLIC_PATHS=/health,/metrics,/docs,/openapi.json,/redoc

# --- v5: Prometheus Monitoring ---
METRICS_ENABLED=True
METRICS_PATH=/metrics

# --- v5: Grafana ---
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin      # сменить в production

# --- Offline / Telemetry ---
HF_HUB_OFFLINE=0
VLLM_NO_USAGE_STATS=1
OLLAMA_NO_TELEMETRY=1

# --- Логирование ---
LOG_LEVEL=INFO
